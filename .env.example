# Flask
ENVIRONMENT=production
FLASK_DEBUG=0
SECRET_KEY=change-this-in-production

# Database (PostgreSQL — required, no fallback)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# SQLAlchemy
# Optional engine tuning via code defaults

# Mail
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password

# OAuth (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=

# Uploads and encryption
UPLOAD_FOLDER=static/uploads
MAX_UPLOAD_SIZE=5242880
ENCRYPTION_KEY=replace-with-32+bytes-secret

# Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_SUB=mailto:admin@example.com

# WebSockets / Socket.IO
ASYNC_MODE=eventlet
SOCKETIO_PING_TIMEOUT=60
SOCKETIO_PING_INTERVAL=25
SOCKETIO_MAX_HTTP_BUFFER_SIZE=100000000
REDIS_URL=

# TURN / ICE configuration
TURN_URLS=
TURN_USER=
TURN_PASS=
ICE_CRED_ROTATE_SECONDS=3600

# Logging
LOG_LEVEL=INFO

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Map of provider->shared secret as JSON, used for generic HMAC webhook verification
PAYMENT_PROVIDER_SECRETS={"mpesa":"replace-with-secret","stripe":"replace-with-whsec"}
# Comma-separated CIDR allowlist for webhook source IPs (optional)
WEBHOOK_IP_ALLOWLIST=
# Idempotency cache TTL in days
IDEMPOTENCY_TTL_DAYS=7

# Feature flags
STRICT_PROFILE_VALIDATION=False

# Security / cookies are set automatically for production

# ============================================
# SEED USERS (one-time, pipe-separated fields)
# ============================================
# These are only created on the FIRST run when the database is empty.
# After seeding completes the app records a marker and never seeds again.
#
# Admin:  username|email|password|first_name|last_name|phone
SEED_ADMIN=admin|admin@makokha.com|Admin@123456|System|Administrator|+254700000000

# Doctors: username|email|password|first_name|last_name|phone|specialization|license_number|experience_years|consultation_fee|qualifications|practitioner_type
SEED_DOCTOR_1=dr_mwangi|dr.mwangi@makokha.com|Doctor@123456|David|Mwangi|+254700000001|General Practitioner|KMC/2020/001|8|1500.00|MBChB, MMed|General Doctor MBChB/MBBS
SEED_DOCTOR_2=dr_ochieng|dr.ochieng@makokha.com|Doctor@123456|Sarah|Ochieng|+254700000002|Pediatrics|KMC/2021/045|5|2000.00|MBChB, MMed Paediatrics|Pediatrician
SEED_DOCTOR_3=dr_kamau|dr.kamau@makokha.com|Doctor@123456|Peter|Kamau|+254700000003|Internal Medicine|KMC/2019/112|12|2500.00|MBChB, MMed Internal Medicine|Internal Medicine

# Patients: username|email|password|first_name|last_name|phone|blood_type|emergency_contact|insurance_provider
SEED_PATIENT_1=john_doe|john.doe@example.com|Patient@123456|John|Doe|+254711000000|O+|Jane Doe +254722000000|NHIF
SEED_PATIENT_2=mary_wanjiku|mary.wanjiku@example.com|Patient@123456|Mary|Wanjiku|+254711000001|A+|Tom Wanjiku +254722000001|AAR
SEED_PATIENT_3=james_kiprop|james.kiprop@example.com|Patient@123456|James|Kiprop|+254711000002|B+|Anne Kiprop +254722000002|Jubilee
SEED_PATIENT_4=grace_akinyi|grace.akinyi@example.com|Patient@123456|Grace|Akinyi|+254711000003|AB+|Paul Akinyi +254722000003|NHIF
